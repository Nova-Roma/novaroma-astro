---
const {
  variant,
  size,
  onlyIconSize,
  gap,
  class: className,
  href,
  type = "button",
  ...rest
} = Astro.props;
const isLink = typeof href !== "undefined";
const Tag = isLink ? "a" : "button";
const attributes = isLink ? { href, ...rest } : { type, ...rest };
// Default
const defaultClass = ["text-white ", "bg-accent-950", "hover:bg-accent-900"];
// Accent — brand gold (arch highlights), text on deep navy
const accentClass = [
  "text-primary",
  "bg-gold-400",
  "hover:bg-gold-300",
  "border",
  "border-gold-500/40",
];
// Muted button
const mutedClass = ["bg-white", "text-accent-700", "hover:bg-base-50"];
// Outline button — portal blue frame
const outlineClass = [
  "ring",
  "ring-inset",
  "ring-accent-600",
  "bg-transparent",
  "text-accent-700",
  "hover:bg-accent-50",
];
// Size (only applies if variant is not "link")
const xs = ["h-9", "px-4", "py-2", "text-sm"];
const sm = ["h-10", "px-4", "py-2", "text-sm"];
const base = ["h-11", "px-6", "py-3", "text-sm"];
const md = ["h-12", "px-6", "py-3", "text-base"];
const lg = ["h-13", "px-6", "py-3", "text-base"];
const xl = ["h-14", "px-6", "py-3", "text-lg"];
// Icon-only sizing
const onlyIconXS = ["w-8", "h-8", "p-0"];
const onlyIconSM = ["w-9", "h-9", "p-0"];
const onlyIconBase = ["w-10", "h-10", "p-0"];
const onlyIconMD = ["w-11", "h-11", "p-0"];
const onlyIconLG = ["w-12", "h-12", "p-0"];
const onlyIconXL = ["w-14", "h-14", "p-0"];
// Gap
const gapXS = ["gap-2"];
const gapSM = ["gap-4"];
const gapBase = ["gap-8"];
const gapMD = ["gap-10"];
const gapLG = ["gap-12"];
const additionalClasses = className ? className.split(" ") : [];
---

<Tag
  class:list={[
    "flex",
    "transition",
    "text-center",
    "justify-center",
    "font-medium",
    "items-center",
    "duration-300",
    "focus:ring-2",
    "focus:outline-none",
    "focus:ring-offset-2",

    variant === "default" && [...defaultClass, "focus:ring-accent-600"],
    variant === "accent" && [...accentClass, "focus:ring-gold-600"],
    variant === "muted" && [...mutedClass, "focus:ring-accent-500"],
    variant === "outline" && [...outlineClass, "focus:ring-accent-500"],
    variant === "none" && [], // No additional classes for "none" variant
    onlyIconSize && size === "xs" && onlyIconXS,
    onlyIconSize && size === "sm" && onlyIconSM,
    onlyIconSize && size === "base" && onlyIconBase,
    onlyIconSize && size === "md" && onlyIconMD,
    onlyIconSize && size === "lg" && onlyIconLG,
    onlyIconSize && size === "xl" && onlyIconXL,
    !onlyIconSize && size === "xs" && xs,
    !onlyIconSize && size === "sm" && sm,
    !onlyIconSize && size === "base" && base,
    !onlyIconSize && size === "md" && md,
    !onlyIconSize && size === "lg" && lg,
    !onlyIconSize && size === "xl" && xl,
    gap === "xs" && gapXS,
    gap === "sm" && gapSM,
    gap === "base" && gapBase,
    gap === "md" && gapMD,
    gap === "lg" && gapLG,
    ...additionalClasses,
  ]}
  {...attributes}
>
  <slot name="left-icon" />
  <slot />
  <slot name="right-icon" />
</Tag>
