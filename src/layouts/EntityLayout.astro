---
import { contentImageToOgUrl } from "@/lib/ogImage";
// Fundations
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Button from "@/components/fundations/elements/Button.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
// Components
import EntityCard from "@/components/entities/EntityCard.astro";
// Content
import { Image } from "astro:assets";
const frontmatter = Astro.props.frontmatter;
const entities = Astro.props.entities || [];
const tierLabels = {
  platinum: "Platinum sponsor",
  gold: "Gold sponsor",
  silver: "Silver sponsor",
  bronze: "Bronze sponsor",
};
const kind = frontmatter.kind ?? "event_sponsor";
const tierLabel =
  kind === "community"
    ? "Community"
    : kind === "partner"
      ? "Partner"
      : tierLabels[frontmatter.tier] || "Partner";
const otherEntities = entities.filter((e) => e.slug !== frontmatter.slug);
const tierOrder = ["platinum", "gold", "silver", "bronze"];
const sortedOtherEntities = otherEntities
  .slice()
  .sort((a, b) => {
    const tierA = tierOrder.indexOf(a.data.tier || "bronze");
    const tierB = tierOrder.indexOf(b.data.tier || "bronze");
    if (tierA !== tierB) return tierA - tierB;
    return a.data.name.localeCompare(b.data.name);
  })
  .slice(0, 6);
const externalUrl = frontmatter.url;
const hasExternalLink = externalUrl && externalUrl !== "#_";
const shareImageUrl = await contentImageToOgUrl(
  Astro.site,
  frontmatter.logo.url
);
const seoDescription =
  frontmatter.description?.trim() ||
  `${frontmatter.name} — ${tierLabel} partner with Nova Roma`;
---

<BaseLayout
  pageTitle={frontmatter.name}
  description={seoDescription}
  imageUrl={shareImageUrl}
  imageAlt={frontmatter.logo.alt || frontmatter.name}
>
  <section>
    <Wrapper variant="standard" class="py-32">
      <div class="grid grid-cols-1 lg:grid-cols-12 items-start">
        <div class="lg:col-span-6">
          <Text tag="p" variant="textXS" class="uppercase text-base-600">
            {tierLabel}
          </Text>
          <Text
            tag="h1"
            variant="displayMD"
            class="text-balance text-accent-500 font-display uppercase leading-tight mt-8"
          >
            {frontmatter.name}
          </Text>
          <Wrapper variant="prose" class="mt-12">
            <slot />
          </Wrapper>
        </div>
        <div
          class="flex flex-col justify-center lg:col-span-4 lg:col-start-9 lg:sticky lg:top-32"
        >
          <div class="bg-accent-500 p-8">
            {
              frontmatter.logo?.url ? (
                <Image
                  src={frontmatter.logo.url}
                  alt={frontmatter.logo.alt || frontmatter.name}
                  width={320}
                  height={200}
                  class="h-24 w-auto object-contain"
                  loading="lazy"
                />
              ) : (
                <div class="flex h-24 w-full items-center justify-center border border-dashed border-white/20 text-xs uppercase   text-base-400">
                  Logo coming soon
                </div>
              )
            }
          </div>
          {
            hasExternalLink ? (
              <Button
                size="sm"
                variant="outline"
                href={externalUrl}
                target="_blank"
                rel="noreferrer"
                class="mt-4"
              >
                Visit website
              </Button>
            ) : null
          }
        </div>
      </div>
      <section class="mt-24 lg:mt-48">
        <Text
          tag="h2"
          variant="displaySM"
          class="font-display uppercase text-accent-500"
        >
          More partners
        </Text>
        <div class="grid md:grid-cols-2 xl:grid-cols-3 mt-4">
          {
            sortedOtherEntities.map((entry) => (
              <EntityCard entity={entry} />
            ))
          }
        </div>
      </section>
    </Wrapper>
  </section>
</BaseLayout>
