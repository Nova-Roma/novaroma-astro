---
// Assets
import { Image } from "astro:assets";
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
// Content
const compact = Astro.props.compact === true;
const postHrefPrefix =
  Astro.props.postHrefPrefix ?? "/insights/posts";
const { url, title, description, pubDate, imageSrc, imageAlt, author } = {
  url: `${postHrefPrefix.replace(/\/$/, "")}/${Astro.props.post.slug}`,
  title: Astro.props.post.data.title,
  description: Astro.props.post.data.description,
  pubDate: new Date(Astro.props.post.data.pubDate).toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  }),
  imageSrc:
    Astro.props.post.data.image?.src ?? Astro.props.post.data.image?.url,
  imageAlt: Astro.props.post.data.image?.alt || Astro.props.post.data.title,
  author: Astro.props.post.data.author,
};
---

<article
  class:list={[
    "group relative flex h-full flex-col bg-accent-500",
    compact && "overflow-hidden rounded-sm",
  ]}
>
  <a href={url} title={title} class="absolute inset-0 z-10"> </a>
  {
    imageSrc ? (
      <Image
        width={compact ? 400 : 640}
        height={compact ? 225 : 800}
        src={imageSrc}
        alt={imageAlt}
        class:list={[
          "w-full object-cover object-center shrink-0",
          compact ? "aspect-video max-h-36" : "aspect-sqaure",
        ]}
        loading="lazy"
      />
    ) : (
      <div
        class:list={[
          "flex w-full items-center justify-center border-b border-dashed border-white/10 text-xs uppercase text-base-400",
          compact ? "aspect-video max-h-36" : "aspect-sqaure",
        ]}
      >
        Image coming soon
      </div>
    )
  }
  <div
    class:list={[
      "flex flex-1 flex-col",
      compact ? "gap-2 p-4" : "gap-4 p-8",
    ]}
  >
    <div class="space-y-2">
      <Text variant="textXS" tag="p" class="uppercase text-white">
        <time datetime={Astro.props.post.data.pubDate}>{pubDate}</time>
      </Text>
      <Text
        tag="h3"
        variant={compact ? "textLG" : "textXL"}
        class:list={[
          "uppercase font-display text-white",
          compact ? "mt-2" : "mt-8",
        ]}
      >
        {title}
      </Text>
      <Text
        tag="p"
        variant="textSM"
        class:list={[
          "text-base-200",
          compact ? "line-clamp-2" : "line-clamp-3",
        ]}
      >
        {description}
      </Text>
    </div>
  </div>
</article>
