---
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
import Button from "@/components/fundations/elements/Button.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
---

<section
  class="pt-16 md:pt-24 lg:pt-32 bg-gradient-to-b from-accent-50/90 via-base-100 to-base-100 border-b border-dashed border-black/10"
>
  <Wrapper variant="standard" class="pt-32 pb-8">
    <div class="grid grid-cols-1 lg:grid-cols-12 items-end">
      <div class="lg:col-span-8 pb-8">
        <Text
          tag="h1"
          variant="displayMD"
          class="text-balance text-accent-800 font-display uppercase leading-tight"
        >
          Nova Roma Horizon 
          <br />
          Innovation Society
        </Text>
        <Text
          tag="p"
          variant="textBase"
          class="text-accent-600 font-medium max-w-2xl mt-2 text-balance"
        >
          A Canadian non-profit bridging legacy institutions and an AI-native
          future. 
          <br /> 
          We operate at the intersection of governance, education, and
          industry to bring about sustainable innovation for a more resilient future. 
        </Text>
        <Button size="sm" variant="accent" href="/initiatives/" class="w-fit mt-8">
          See Our Initiatives
        </Button>
      </div>
      <div
        aria-hidden="true"
        class="hidden lg:grid grid-cols-2 lg:grid-cols-4 *:p-8 *:aspect-square *:bg-gradient-to-br *:from-accent-500 *:to-accent-800 *:flex lg:col-span-4 *:size-full"
      >
        <div class="lg:col-start-2"></div>
        <div class="lg:col-start-4"></div>
        <div></div>
        <div></div>
      </div>
    </div>
    <div
      aria-hidden="true"
      class="w-full h-full relative lg:col-span-5 h-full p-20 p-4 aspect-16/4 bg-gradient-to-r from-accent-800 via-accent-600 to-accent-500"
    >
    </div>
  </Wrapper>
</section>
