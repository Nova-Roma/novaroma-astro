---
import { Image } from "astro:assets";
import Text from "@/components/fundations/elements/Text.astro";
const entity = Astro.props.entity;
const { name, logo } = entity.data;
const detailUrl = `/entities/details/${entity.slug}`;
const logoAlt = logo?.alt || name;
---

<article class="relative bg-accent-500 hover:bg-accent-900">
  <a
    href={detailUrl}
    title={name}
    class="absolute inset-0 z-10"
    aria-label={`${name} details`}></a>
  <div class="flex flex-col items-center justify-center p-8 text-center">
    {
      logo?.url ? (
        <Image
          src={logo.url}
          alt={logoAlt}
          width={logo.width ?? 400}
          height={logo.height ?? 220}
          loading="lazy"
          class="h-20 w-auto max-w-full object-contain sm:h-24 md:h-28"
        />
      ) : (
        <div class="flex min-h-20 sm:min-h-24 md:min-h-28 w-full items-center justify-center text-xs uppercase text-base-400">
          Logo coming soon
        </div>
      )
    }
    <Text tag="h3" variant="textLG" class="sr-only">
      {name}
    </Text>
  </div>
</article>
