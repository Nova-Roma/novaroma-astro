---
// Fundations
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
// Content
const { frontmatter } = Astro.props;
---

<BaseLayout
  pageTitle={frontmatter.page}
  description={`${frontmatter.page} — Nova Roma`}
>
  <section>
    <Wrapper variant="standard" class="py-32">
      <div>
        <Text
          tag="h1"
          variant="displayMD"
          class="text-balance text-accent-500 font-display uppercase leading-tight mt-8"
        >
          {frontmatter.page}
        </Text>
       
      </div>
      <Wrapper variant="prose" class="mt-12">
        <slot />
      </Wrapper>
    </Wrapper>
  </section>
</BaseLayout>
