---
// Fundations
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Button from "@/components/fundations/elements/Button.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
// Components
import SpeakerCard from "@/components/speakers/SpeakerCard.astro";
// Content
import { getCollection } from "astro:content";
const people = await getCollection("people");

const allPeople = people
  .filter((person) => !person.data.featured)
  .sort((a, b) => a.data.name.localeCompare(b.data.name));
const totalPeople = people.length;
---

<BaseLayout>
  <section>
    <Wrapper variant="standard" class="py-32">
      <div>
        <Text tag="p" variant="textXS" class="uppercase text-base-600">
          Network
        </Text>
        <Text
          tag="h1"
          variant="displayMD"
          class="text-balance text-accent-500 font-display uppercase leading-tight mt-8"
        >
          People
        </Text>
        <Text
          tag="p"
          variant="textBase"
          class="text-base-600 font-medium max-w-2xl mt-2 text-balance"
        >
          {totalPeople} profiles including event presenters, facilitators, and
          contributors. The full Nova Roma roster spans core team, partners,
          speakers, and guests.
        </Text>
      </div>

      <div class="grid grid-cols-1 mt-12 lg:grid-cols-12">
        <div class="space-y-2 lg:col-span-3">
          <Text
            tag="h2"
            variant="displaySM"
            class="font-display uppercase text-accent-500"
          >
            Full roster
          </Text>
          <Text tag="p" variant="textSM" class="text-base-600 text-balance">
            Workshop leads, resident mentors, and panelists across the programme.
          </Text>
        </div>
        <div class="grid sm:grid-cols-2 xl:grid-cols-3 lg:col-span-9 gap-y-12">
          {allPeople.map((person) => <SpeakerCard speaker={person} />)}
        </div>
      </div>
      <section
        class="gap-x-12 gap-y-8 border border-white/10 bg-accent-500 p-8 md:flex md:items-center md:justify-between mt-24"
      >
        <div class="max-w-2xl space-y-4">
          <Text
            tag="h2"
            variant="displaySM"
            class="font-display uppercase text-white"
          >
            Join the network
          </Text>
          <Text tag="p" variant="textSM" class="text-base-200 lg:text-balance">
            Interested in contributing or speaking? Email <a
              class="underline"
              href="mailto:hello@novaromahorizon.org">hello@novaromahorizon.org</a
            > with your topic and relevant links.
          </Text>
        </div>
        <div
          class="flex flex-wrap items-center justify-center gap-2 md:justify-end"
        >
          <Button
            size="sm"
            variant="default"
            class="w-fit"
            href="/forms/register"
          >
            Register
          </Button>
          <Button
            size="sm"
            variant="muted"
            class="w-fit"
            href="mailto:hello@novaromahorizon.org"
          >
            Propose a session
          </Button>
        </div>
      </section>
    </Wrapper>
  </section>
</BaseLayout>
