---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import Text from "@/components/fundations/elements/Text.astro";
import SessionCard from "@/components/sessions/SessionCard.astro";
import { getCollection } from "astro:content";

const sessions = await getCollection("sessions");

const sessionsByDay = sessions.reduce((acc, session) => {
  const key = session.data.day;
  if (!acc[key]) {
    acc[key] = [];
  }
  acc[key].push(session);
  return acc;
}, {});

const dayOrder = [
  "day-1",
  "day-2",
  "day-3",
  "day-4",
  "day-5",
  "day-6",
  "day-7",
];

const dayLabels = {
  "day-1": "Day 1",
  "day-2": "Day 2",
  "day-3": "Day 3",
  "day-4": "Day 4",
  "day-5": "Day 5",
  "day-6": "Day 6",
  "day-7": "Day 7",
};

const orderedDays = dayOrder
  .map((dayKey) => ({
    key: dayKey,
    sessions: (sessionsByDay[dayKey] || []).sort(
      (a, b) =>
        new Date(a.data.start).getTime() - new Date(b.data.start).getTime()
    ),
  }))
  .filter((group) => group.sessions.length > 0);
---

<BaseLayout>
  <section>
    <Wrapper variant="standard" class="py-32">
      <div>
        <Text tag="p" variant="textXS" class="uppercase text-base-600">
          Programme
        </Text>
        <Text
          tag="h1"
          variant="displayMD"
          class="text-balance text-accent-500 font-display uppercase leading-tight mt-8"
        >
          Sessions & ateliers
        </Text>
        <Text
          tag="p"
          variant="textBase"
          class="text-base-600 font-medium max-w-2xl mt-2 text-balance"
        >
          Explore every keynote, critique, and lab across the seven-day
          programme. Each session blends Swiss design discipline with applied
          practice for contemporary product teams.
        </Text>
      </div>

      <div class="space-y-24 lg:space-y-48 mt-12">
        {
          orderedDays.map((day) => (
            <div class="grid grid-cols-1 lg:grid-cols-12 items-start">
              <div class="lg:col-span-3">
                <Text
                  tag="h2"
                  variant="displaySM"
                  class="font-display uppercase text-accent-500"
                >
                  {dayLabels[day.key] || day.key}
                </Text>
                <Text
                  tag="p"
                  variant="textXS"
                  class="  uppercase text-base-600"
                >
                  {`${day.sessions.length} ${day.sessions.length > 1 ? "sessions" : "session"}`}
                </Text>
              </div>

              <div class="grid md:grid-cols-2 lg:grid-cols-3 lg:col-span-9 gap-y-12">
                {day.sessions.map((session) => (
                  <SessionCard session={session} />
                ))}
              </div>
            </div>
          ))
        }
      </div>

      <section
        class="gap-12 border border-white/10 bg-base-900/60 p-8 md:flex md:items-center md:justify-between"
      >
        <div class="max-w-2xl space-y-4">
          <Text
            tag="h2"
            variant="displaySM"
            class="font-display uppercase text-white"
          >
            Build your itinerary
          </Text>
          <Text tag="p" variant="textSM" class="text-base-200">
            Use the schedule to plan your day-by-day flow. Download the full
            programme or register to receive personalised itineraries and
            session reminders.
          </Text>
        </div>
        <div
          class="mt-6 flex flex-wrap items-center justify-center gap-4 md:mt-0 md:justify-end"
        >
          <a
            href="/schedule"
            class="border border-white/30 bg-white/10 px-5 py-3 text-xs uppercase text-white transition hover:border-white/60"
          >
            View schedule
          </a>
          <a
            href="/forms/register"
            class="border border-accent-500 bg-accent-500 px-5 py-3 text-xs uppercase text-white transition hover:bg-accent-400"
          >
            Register now
          </a>
        </div>
      </section>
    </Wrapper>
  </section>
</BaseLayout>
