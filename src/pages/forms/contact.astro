---
// Fundations
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Button from "@/components/fundations/elements/Button.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import { getCollection } from "astro:content";

const initiatives = await getCollection("initiatives");
initiatives.sort((a, b) =>
  a.data.title.localeCompare(b.data.title, undefined, { sensitivity: "base" })
);
---

<BaseLayout
  pageTitle="Contact"
  description="Connect with the Nova Roma team — questions, partnerships, and press."
>
  <section>
    <Wrapper variant="standard" class="py-32">
      <div>
        <Text
          tag="h1"
          variant="displayMD"
          class="text-balance text-accent-500 font-display uppercase leading-tight"
        >
          Connect with the Nova Roma team
        </Text>
        <Text
          tag="p"
          variant="textBase"
          class="text-base-600 font-medium max-w-2xl mt-2 text-balance"
        >
          Reach out to us using the form below.
        </Text>
      </div>
      <div class="grid lg:grid-cols-12 mt-8">
        <form
          class="bg-accent-500 p-8 lg:col-span-4 space-y-8"
          method="post"
          action="mailto:hello@novaromahorizon.org?subject=Contact%20from%20novaromahorizon.org"
          enctype="text/plain"
          aria-labelledby="contact-title"
        >
          <h2 id="contact-title" class="sr-only">Contact form</h2>
          <!-- Name -->
          <div class="flex flex-col gap-2">
            <label for="name" class="uppercase text-white text-xs tracking-wide"
              >Name</label
            >
            <input
              id="name"
              type="text"
              name="name"
              required
              autocomplete="name"
              class="w-full bg-black/15 border-transparent px-4 py-3 h-11 text-xs text-white placeholder:text-base-50 focus:border-white/60 focus:outline-none"
            />
          </div>
          <!-- Email -->
          <div class="flex flex-col gap-2">
            <label
              for="email"
              class="uppercase text-white text-xs tracking-wide">Email</label
            >
            <input
              id="email"
              type="email"
              name="email"
              required
              autocomplete="email"
              class="w-full bg-black/15 border-transparent px-4 py-3 h-11 text-xs text-white placeholder:text-base-50 focus:border-white/60 focus:outline-none"
            />
          </div>
          <!-- Organization (optional) -->
          <div class="flex flex-col gap-2">
            <label
              for="organization"
              class="uppercase text-white text-xs tracking-wide"
              >Organization <dt class="normal-case lowercase text-white/70">
                (optional)
              </dt></label
            >
            <input
              id="organization"
              type="text"
              name="organization"
              autocomplete="organization"
              class="w-full bg-black/15 border-transparent px-4 py-3 h-11 text-xs text-white placeholder:text-base-50 focus:border-white/60 focus:outline-none"
            />
          </div>
          <!-- Topic -->
          <div class="flex flex-col gap-2">
            <label
              for="topic"
              class="uppercase text-white text-xs tracking-wide">Topic</label
            >
            <select
              id="topic"
              name="topic"
              class="w-full bg-black/15 border-transparent px-4 py-3 h-11 text-xs text-white placeholder:text-base-50 focus:border-white/60 focus:outline-none [color-scheme:dark]"
            >
              <option value="general">General inquiry</option>
              {initiatives.map((entry) => (
                <option value={entry.slug}>{entry.data.title}</option>
              ))}
            </select>
          </div>
          <!-- Message -->
          <div class="flex flex-col gap-2">
            <label
              for="message"
              class="uppercase text-white text-xs tracking-wide">Message</label
            >
            <textarea
              id="message"
              name="message"
              rows="6"
              required
              autocomplete="off"
              aria-describedby="message-hint"
              class="w-full bg-black/15 border-transparent px-4 py-3 h-11 text-xs text-white placeholder:text-base-50 focus:border-white/60 focus:outline-none"
            ></textarea>
            <p id="message-hint" class="text-xs text-white">
              Please include any relevant links and information.
            </p>
          </div>
          <!-- Subscribe -->
          <div>
            <div class="flex items-start gap-3 text-xs text-white">
              <input
                id="subscribe"
                type="checkbox"
                name="subscribe"
                class="mt-1 border-base-400 accent-white focus:outline-none focus-visible:ring-2 focus-visible:ring-white/70"
              />
              <label for="subscribe" class="cursor-pointer">
                Keep me updated on speaker reveals, residencies, and future Nova Roma events.
              </label>
            </div>
            <!-- Submit -->
            <Button
              type="submit"
              size="base"
              variant="muted"
              class="w-full mt-4"
            >
              Send us a message!
            </Button>
          </div>
        </form>
        <aside class="lg:col-span-3 lg:col-start-6">
          <div class="space-y-4">
            <Text
              tag="h2"
              variant="textXL"
              class="font-display uppercase text-accent-500"
            >
              Direct lines
            </Text>
            <dl
              class="divide-y divide-dashed divide-black/10 text-base-200 mt-8 border-y border-dashed border-black/10"
            >
              <div class="py-4">
                <dt class="font-display uppercase text-accent-500">General</dt>
                <dd>
                  <a  class="underline text-base-600" href="mailto:hello@novaromahorizon.org"
                    >hello@novaromahorizon.org</a
                  >
                </dd>
              </div>
              <div class="py-4">
                <dt class="font-display uppercase text-accent-500">Careers</dt>
                <dd>
                  <a  class="underline text-base-600" href="mailto:careers@novaromahorizon.org"
                    >careers@novaromahorizon.org</a
                  >
                </dd>
              </div>
              <div class="py-4">
                <dt class="font-display uppercase text-accent-500">
                  Partnerships
                </dt>
                <dd>
                  <a  class="underline text-base-600" href="mailto:partners@novaromahorizon.org"
                    >partners@novaromahorizon.org</a
                  >
                </dd>
              </div>
            </dl>
          </div>
          <div class="space-y-4 border-t border-white/10 pt-6">
            <Text
              tag="h2"
              variant="textXL"
              class="font-display uppercase text-accent-500"
            >
              Mailing address
            </Text>
            <Text tag="p" variant="textBase" class="text-base-600">
              Nova Roma Horizon Innovation Society<br>
              2061 Muskoka Rd 169, Gravenhurst<br>
              Ontario, Canada. P1P 1R2
            </Text>
          </div>
        </aside>
      </div>
    </Wrapper>
  </section>
</BaseLayout>

<style is:global>
  /* Native option lists often use a light panel while inheriting light text from the control. */
  #topic option {
    background-color: var(--color-base-950);
    color: var(--color-base-50);
  }
</style>
