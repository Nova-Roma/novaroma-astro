---
import SessionsLayout from "@/layouts/SessionsLayout.astro";
import { getCollection } from "astro:content";
export async function getStaticPaths() {
  const sessionEntries = await getCollection("sessions");
  return sessionEntries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry, sessions: sessionEntries },
  }));
}
const { entry, sessions } = Astro.props;
const { Content } = await entry.render();

let speakerSocials = [];
if (import.meta.env.SSR) {
  const allPeople = await getCollection("people");
  speakerSocials = (entry.data.people || []).map((slug) => {
    const person = allPeople.find((p) => p.slug === slug);
    return person
      ? { slug, socials: person.data.socials }
      : { slug, socials: {} };
  });
}
---

<SessionsLayout
  frontmatter={entry.data}
  sessions={sessions}
  speakerSocials={speakerSocials}
  slug={entry.slug}
>
  <Content />
</SessionsLayout>
