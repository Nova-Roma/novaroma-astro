---
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
import Button from "@/components/fundations/elements/Button.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
// People
import SpeakerCard from "@/components/speakers/SpeakerCard.astro";
import { getCollection } from "astro:content";
const people = await getCollection("people");
---

<section>
  <Wrapper variant="standard" class="py-24">
    <div class="grid grid-cols-1 gap-y-8 lg:grid-cols-12">
      <Text
        tag="p"
        variant="textXS"
        class="uppercase text-base-600 lg:col-span-3 w-full"
      >
        People
      </Text>
      <div class="lg:col-span-6 lg:-mt-4">
        <Text
          tag="h2"
          variant="displayXL"
          class="font-display uppercase leading-tight text-accent-500"
        >
          Featured profiles
        </Text>
        <Text tag="p" variant="textSM" class="text-base-600 text-balance">
          A sample of people from the Network, including presenters tied to
          the event sessions collection.
        </Text>
      </div>
      <div class="flex flex-col gap-2 lg:col-start-12">
        <Button href="/people" size="sm" variant="outline" class="w-full">
          All people
        </Button>
        <Text tag="p" variant="textXS" class="text-base-500"
          >Featured cohort • {people.length} people</Text
        >
      </div>
    </div>
    <div
      class="session-grid mt-8 grid sm:grid-cols-2 xl:grid-cols-4 border-y border-dashed border-white/5"
    >
      {people.slice(0, 4).map((person) => <SpeakerCard speaker={person} />)}
    </div>
  </Wrapper>
</section>
