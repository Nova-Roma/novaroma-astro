---
// Fundations
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
const colorGroups = [
  {
    title: "Black and white",
    colors: [
      { label: "White", class: "bg-white border border-base-300" },
      { label: "Black", class: "bg-black" },
    ],
  },
  {
    title: "Base",
    colors: [
      { label: "Base 50", class: "bg-base-50" },
      { label: "Base 100", class: "bg-base-100" },
      { label: "Base 200", class: "bg-base-200" },
      { label: "Base 300", class: "bg-base-300" },
      { label: "Base 400", class: "bg-base-400" },
      { label: "Base 500", class: "bg-base-500" },
      { label: "Base 600", class: "bg-base-600" },
      { label: "Base 700", class: "bg-base-700" },
      { label: "Base 800", class: "bg-base-800" },
      { label: "Base 900", class: "bg-base-900" },
      { label: "Base 950", class: "bg-base-950" },
    ],
  },
  {
    title: "Primary",
    colors: [
      { label: "Primary #011122", class: "bg-primary border border-white/20" },
    ],
  },
  {
    title: "Gold (accent)",
    colors: [
      { label: "Gold 50", class: "bg-gold-50 border border-black/10" },
      { label: "Gold 100", class: "bg-gold-100 border border-black/10" },
      { label: "Gold 200", class: "bg-gold-200 border border-black/10" },
      { label: "Gold 300", class: "bg-gold-300 border border-black/10" },
      { label: "Gold 400", class: "bg-gold-400 border border-black/10" },
      { label: "Gold 500", class: "bg-gold-500 border border-black/10" },
      { label: "Gold 600", class: "bg-gold-600 border border-black/10" },
      { label: "Gold 700", class: "bg-gold-700 border border-black/10" },
    ],
  },
  {
    title: "Accent (portal blue)",
    colors: [
      { label: "Accent 50", class: "bg-accent-50" },
      { label: "Accent 100", class: "bg-accent-100" },
      { label: "Accent 200", class: "bg-accent-200" },
      { label: "Accent 300", class: "bg-accent-300" },
      { label: "Accent 400", class: "bg-accent-400" },
      { label: "Accent 500", class: "bg-accent-500" },
      { label: "Accent 600", class: "bg-accent-600" },
      { label: "Accent 700", class: "bg-accent-700" },
      { label: "Accent 800", class: "bg-accent-800" },
      { label: "Accent 900", class: "bg-accent-900" },
      { label: "Accent 950", class: "bg-accent-950" },
    ],
  },
];
---

<BaseLayout pageTitle="Colors" description="Design system color tokens." noindex>
  <section>
    <Wrapper variant="standard" class="pb-8 pt-32 border-t">
      <Text
        tag="h1"
        variant="displayMD"
        class="text-balance text-accent-500 font-display uppercase leading-tight"
        >Colors</Text
      >
      <div
        class="flex flex-col divide-y divide-black/10 divide-dashed border-y border-dashed border-black/10 text-base-400 mt-12"
      >
        {
          colorGroups.map((group) => (
            <div class="py-6">
              <Text
                tag="h3"
                variant="textBase"
                class="text-accent-500 uppercase font-display"
              >
                {group.title}
              </Text>
              <div class="grid grid-cols-3 gap-y-12 md:grid-cols-4 lg:grid-cols-12 mt-8 pt-8 border-t border-dashed border-black/10">
                {group.colors.map((color) => (
                  <div class="flex flex-col items-center gap-4">
                    <div class={`p-4 size-12 rounded-full ${color.class}`} />
                    <span class="text-xs text-base-500">{color.label}</span>
                  </div>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </Wrapper>
  </section>
</BaseLayout>
