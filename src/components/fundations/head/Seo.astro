---
import { AstroSeo } from "@astrolib/seo";
import { DEFAULT_DESCRIPTION, SITE_NAME } from "@/lib/site";
import type { PageArticleMeta } from "@/lib/seoTypes";

interface Props {
  /** Full string for `<title>` (e.g. "About | Nova Roma"). */
  title: string;
  /** Short headline for Open Graph / Twitter (e.g. "About"). */
  ogTitle: string;
  description?: string;
  canonical: string;
  /** Absolute URL for og:image / twitter:image */
  imageUrl: string;
  imageAlt?: string;
  ogType?: "website" | "article";
  article?: PageArticleMeta;
  noindex?: boolean;
}

const {
  title,
  ogTitle,
  description = DEFAULT_DESCRIPTION,
  canonical,
  imageUrl,
  imageAlt = SITE_NAME,
  ogType = "website",
  article,
  noindex = false,
} = Astro.props;

const desc = description.trim() || DEFAULT_DESCRIPTION;
---

<AstroSeo
  title={title}
  description={desc}
  canonical={canonical}
  noindex={noindex}
  nofollow={false}
  openGraph={{
    url: canonical,
    title: ogTitle,
    description: desc,
    site_name: SITE_NAME,
    type: ogType,
    locale: "en_US",
    images: [
      {
        url: imageUrl,
        width: 1200,
        height: 630,
        alt: imageAlt,
      },
    ],
    article: ogType === "article" ? article : undefined,
  }}
  twitter={{
    handle: "@novaroma",
    site: "@novaroma",
    cardType: "summary_large_image",
  }}
  additionalMetaTags={[
    { name: "twitter:url", content: canonical },
    { name: "twitter:title", content: ogTitle },
    { name: "twitter:description", content: desc },
    { name: "twitter:image", content: imageUrl },
    { name: "twitter:image:alt", content: imageAlt },
  ]}
/>
