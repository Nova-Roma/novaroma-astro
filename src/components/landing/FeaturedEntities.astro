---
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
import Button from "@/components/fundations/elements/Button.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import EntityCard from "@/components/entities/EntityCard.astro";
import { getCollection } from "astro:content";

const tierOrder = ["platinum", "gold", "silver", "bronze"];
const byTierThenName = (
  a: { data: { tier?: string; name: string } },
  b: { data: { tier?: string; name: string } }
) => {
  const ta = tierOrder.indexOf(a.data.tier ?? "bronze");
  const tb = tierOrder.indexOf(b.data.tier ?? "bronze");
  if (ta !== tb) return ta - tb;
  return a.data.name.localeCompare(b.data.name);
};

const allEntities = await getCollection("entities");
let entities = allEntities
  .filter((e) => e.data.featured)
  .sort(byTierThenName);
if (entities.length === 0) {
  entities = [...allEntities].sort(byTierThenName).slice(0, 4);
}
const display = entities.slice(0, 4);
---

{
  display.length > 0 && (
    <section>
      <Wrapper variant="standard" class="py-24">
        <div class="grid grid-cols-1 gap-y-8 lg:grid-cols-12">
          <div class="lg:col-span-6 lg:-mt-4">
            <Text
              tag="h2"
              variant="displayXL"
              class="font-display uppercase leading-tight text-accent-500"
            >
              Communities
            </Text>
            <Text tag="p" variant="textSM" class="text-base-600 text-balance">
              Communities, sponsors, and collaborators in the Nova Roma ecosystems.
            </Text>
          </div>
          <div class="flex flex-col gap-2 lg:col-start-12">
            <Button
              href="/ecosystems"
              size="sm"
              variant="outline"
              class="w-full"
            >
              See all
            </Button>
          </div>
        </div>
        <div class="mt-8 grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-0 border border-dashed border-black/10">
          {display.map((entity) => (
            <EntityCard entity={entity} />
          ))}
        </div>
      </Wrapper>
    </section>
  )
}
