---
// Fundations
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
// Components
import BlogEntry from "@/components/blog/BlogEntry.astro";
// Content
import { getCollection } from "astro:content";
const allPosts = await getCollection("insights");
allPosts.sort(
  (a, b) =>
    new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
);
const featuredPosts = allPosts.slice(0, 3);
const remainingPosts = allPosts.slice(3);
const TOTAL_COUNT = allPosts.length;
---

<BaseLayout>
  <section>
    <Wrapper variant="standard" class="py-32">
      <header class="max-w-4xl space-y-4">
        <Text
          tag="h1"
          variant="displayMD"
          class="text-balance text-accent-500 font-display uppercase leading-tight"
        >
          Insights
        </Text>
        <Text
          tag="p"
          variant="textBase"
          class="text-accent-600 font-medium max-w-2xl mt-2 text-balance"
        >
          {TOTAL_COUNT} research notes, field reports, and event journals. Written
          output from the Nova Roma network, often co-authored with members and
          partners.
        </Text>
      </header>
      <div class="mt-12 space-y-24 lg:space-y-48">
        {
          featuredPosts.length > 0 && (
            <section>
              <Text
                tag="h2"
                variant="displaySM"
                class="font-display  uppercase text-accent-500"
              >
                Editor’s spotlight
              </Text>
              <div class="grid lg:grid-cols-3 mt-4">
                {featuredPosts.map((post) => (
                  <BlogEntry post={post} variant="featured" />
                ))}
              </div>
            </section>
          )
        }
        {
          remainingPosts.length > 0 && (
            <section>
              <Text
                tag="h2"
                variant="displaySM"
                class="font-display  uppercase text-accent-500"
              >
                Latest
              </Text>
              <div class="grid lg:grid-cols-3 mt-4">
                {remainingPosts.map((post) => (
                  <BlogEntry post={post} />
                ))}
              </div>
            </section>
          )
        }
      </div>
    </Wrapper>
  </section>
</BaseLayout>
