---
import "@/styles/global.css";
import BaseHead from "@/components/fundations/head/BaseHead.astro";
import Navigation from "@/components/global/Navigation.astro";
import Footer from "@/components/global/Footer.astro";
import GuidelinesGrid from "@/components/assets/GuidelinesGrid.astro";
import { defaultShareImageUrl } from "@/lib/ogImage";
import { DEFAULT_DESCRIPTION, SITE_NAME, SITE_NAME_FULL } from "@/lib/site";
import type { PageArticleMeta } from "@/lib/seoTypes";

interface Props {
  /** Short page name for `<title>` and sharing (e.g. "About", article title). Omit on home. */
  pageTitle?: string;
  description?: string;
  /** Absolute URL for Open Graph / Twitter image; defaults to logo. */
  imageUrl?: string;
  imageAlt?: string;
  ogType?: "website" | "article";
  article?: PageArticleMeta;
  noindex?: boolean;
}

const {
  pageTitle,
  description = DEFAULT_DESCRIPTION,
  imageUrl: imageUrlProp,
  imageAlt,
  ogType = "website",
  article,
  noindex,
} = Astro.props;

const site = Astro.site ?? new URL("https://novaromahorizon.org/");
const canonical = new URL(Astro.url.pathname, site).href;
const defaultImage = await defaultShareImageUrl(Astro.site);
const imageUrl = imageUrlProp ?? defaultImage;

const documentTitle = pageTitle
  ? `${pageTitle} | ${SITE_NAME}`
  : SITE_NAME_FULL;
const ogTitle = pageTitle ?? SITE_NAME_FULL;
const resolvedImageAlt = imageAlt ?? (pageTitle ? SITE_NAME : SITE_NAME_FULL);
---

<html lang="en" class="scroll-smooth scrollbar-hide">
  <head>
    <BaseHead
      title={documentTitle}
      ogTitle={ogTitle}
      description={description}
      canonical={canonical}
      imageUrl={imageUrl}
      imageAlt={resolvedImageAlt}
      ogType={ogType}
      article={article}
      noindex={noindex}
    />
  </head>
  <body class="bg-base-100 flex flex-col min-h-svh">
    <Navigation />
    <main class="grow relative z-10 relative"><slot /></main>
    <Footer />
    <GuidelinesGrid />
  </body>
</html>
