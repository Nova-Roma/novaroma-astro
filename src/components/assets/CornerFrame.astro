---
interface Props {
  class?: string;
}
const { class: className = "" } = Astro.props;
---
<span
  aria-hidden="true"
  class={`pointer-events-none absolute inset-0 ${className}`.trim()}
>
  <span class="absolute left-0 top-0 w-2 h-px bg-gold-400 transition-all duration-300 ease-out group-hover:w-4"></span>
  <span class="absolute left-0 top-0 h-2 w-px bg-gold-400 transition-all duration-300 ease-out group-hover:h-4"></span>
  <span class="absolute right-0 top-0 w-2 h-px bg-gold-400 transition-all duration-300 ease-out group-hover:w-4"></span>
  <span class="absolute right-0 top-0 h-2 w-px bg-gold-400 transition-all duration-300 ease-out group-hover:h-4"></span>
  <span class="absolute left-0 bottom-0 w-2 h-px bg-gold-400 transition-all duration-300 ease-out group-hover:w-4"></span>
  <span class="absolute left-0 bottom-0 h-2 w-px bg-gold-400 transition-all duration-300 ease-out group-hover:h-4"></span>
  <span class="absolute right-0 bottom-0 w-2 h-px bg-gold-400 transition-all duration-300 ease-out group-hover:w-4"></span>
  <span class="absolute right-0 bottom-0 h-2 w-px bg-gold-400 transition-all duration-300 ease-out group-hover:h-4"></span>
</span>
